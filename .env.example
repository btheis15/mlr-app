# Supabase — PUBLIC, client-safe values (the publishable key is meant to ship
# in the browser; data access is gated by row-level security).
#
# Local dev: copy this to `.env.local` and fill in your project's values.
# Production: set the same two in Vercel (Project Settings → Environment
# Variables) and as GitHub Actions repo *variables* for the Pages build.
NEXT_PUBLIC_SUPABASE_URL=https://YOUR-PROJECT.supabase.co
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=sb_publishable_xxxxxxxxxxxxxxxx

# Self-hosted media server (the Mac mini's stable tunnel URL). When set, post +
# committee-chat photos/videos upload here instead of Supabase Storage (no size
# cap). Leave unset to fall back to Supabase Storage. See media-server/.
NEXT_PUBLIC_MEDIA_URL=https://brians-mac-mini.tail49943c.ts.net

# Committee-chat GIF search (Tenor / Google). Optional + free: get a key at
# https://developers.google.com/tenor/guides/quickstart. With no key, the GIF
# button shows a tasteful "not set up yet" note — emojis, stickers, and photos
# all still work. Public, client-safe value.
NEXT_PUBLIC_TENOR_KEY=
