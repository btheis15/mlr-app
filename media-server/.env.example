# MLR media server — copy to .env and fill in.

# The STABLE public HTTPS address of your tunnel (filled in after step 5 below).
# The app stores the URLs this returns, so it must NOT change over time.
PUBLIC_URL=https://YOUR-MINI.YOUR-TAILNET.ts.net

# Cloud Supabase — used only to verify an uploader is a signed-in member.
# (Public, client-safe values — same ones the app uses.)
SUPABASE_URL=https://vrksrpzlslrcjvbzchfg.supabase.co
SUPABASE_ANON_KEY=sb_publishable_XHnrbQ8FHY4xEtAGrk45JQ_Kw0rLlqJ

# Which app origins may upload (comma-separated).
ALLOWED_ORIGINS=https://mlr-app-omega.vercel.app,https://btheis15.github.io,http://localhost:3000

# Where to store files on the mini (an external drive path is fine). Defaults to ./media
# MEDIA_DIR=/Volumes/Media/mlr

# Per-file cap in MB (your disk is the real limit). Default 1024 (1 GB).
# MAX_MB=2048

# Local port the server listens on (the tunnel points here).
PORT=8787

# ── Alert emails (optional) ──────────────────────────────────────────────────
# When set, the mini emails opted-in members whenever an app admin or Family Fest
# lead posts a broadcast alert. Leave any blank to keep emailing OFF (the in-app
# banner still works). See alert-mailer.js.
#
# ⚠️ SERVICE ROLE KEY is powerful — it bypasses row-level security to read member
# emails. Keep it ONLY here on the mini; never put it in the app/client.
# SUPABASE_SERVICE_ROLE_KEY=
#
# SMTP — reuse the SAME credentials you already set up in Supabase Auth → SMTP
# (any provider works). Port 465 ⇒ TLS; 587 ⇒ STARTTLS (or set SMTP_SECURE=true).
# SMTP_HOST=smtp.your-provider.com
# SMTP_PORT=587
# SMTP_USER=your-smtp-username
# SMTP_PASS=your-smtp-password
# ALERT_FROM=Muskellunge Lake Resort <alerts@yourdomain.com>   # match your sender
# APP_URL=https://mlr-app-omega.vercel.app
#
# (Gmail shortcut instead of the SMTP_* block: a Gmail address + an APP password
#  from https://myaccount.google.com/apppasswords)
# GMAIL_USER=you@gmail.com
# GMAIL_APP_PASSWORD=xxxxxxxxxxxxxxxx
