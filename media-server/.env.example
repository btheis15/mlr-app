# MLR media server — copy to .env and fill in.

# The STABLE public HTTPS address of your tunnel (filled in after step 5 below).
# The app stores the URLs this returns, so it must NOT change over time.
PUBLIC_URL=https://YOUR-MINI.YOUR-TAILNET.ts.net

# Cloud Supabase — used only to verify an uploader is a signed-in member.
# (Public, client-safe values — same ones the app uses.)
SUPABASE_URL=https://vrksrpzlslrcjvbzchfg.supabase.co
SUPABASE_ANON_KEY=sb_publishable_XHnrbQ8FHY4xEtAGrk45JQ_Kw0rLlqJ

# Which app origins may upload (comma-separated).
ALLOWED_ORIGINS=https://mlr-app-omega.vercel.app,https://btheis15.github.io,http://localhost:3000

# Where to store files on the mini (an external drive path is fine). Defaults to ./media
# MEDIA_DIR=/Volumes/Media/mlr

# Per-file cap in MB (your disk is the real limit). Default 1024 (1 GB).
# MAX_MB=2048

# Local port the server listens on (the tunnel points here).
PORT=8787

# ── Video transcoding (recommended) ──────────────────────────────────────────
# Normalizes uploaded videos to a web-friendly H.264 MP4 capped at ~1080p, so
# iPhone HEVC/.mov clips play on every device and 4K clips don't balloon the disk
# or everyone's data. Photos are NOT touched (left full quality). A clip that's
# already H.264 MP4 within the size cap is passed through untouched.
#
# Requires ffmpeg on the mini:   brew install ffmpeg
# If ffmpeg isn't installed, uploads still work — videos are just stored as-is.
#
# VIDEO_TRANSCODE=off          # set to "off" to disable entirely (default: on)
# VIDEO_MAX_LONG_EDGE=1920     # long-side cap in px (1920 ⇒ ~1080p; never upscales)
# VIDEO_CRF=20                 # quality 18–23, lower = better/bigger (default 20)
# VIDEO_PRESET=veryfast        # x264 speed/efficiency (ultrafast…slow; default veryfast)
# VIDEO_AUDIO_KBPS=128         # AAC audio bitrate
# VIDEO_TIMEOUT_MS=900000      # max time for one transcode (default 15 min)
# FFMPEG_PATH=ffmpeg           # override if ffmpeg/ffprobe aren't on PATH
# FFPROBE_PATH=ffprobe

# ── Push notifications (optional) ────────────────────────────────────────────
# When set, the mini sends web-push notifications for new chat messages and
# broadcast alerts, filtered by each member's chosen level (Profile → Notifications).
# Works on Android and on iPhones that have added the app to the Home Screen.
# Leave the VAPID keys blank to keep push OFF.
#
# Generate the VAPID key pair ONCE (on the mini, after `npm install`):
#     npx web-push generate-vapid-keys
# Put the PRIVATE key here, and the PUBLIC key BOTH here and in the app as
# NEXT_PUBLIC_VAPID_PUBLIC_KEY (Vercel env) — the public key must match on both.
#
# Needs SUPABASE_SERVICE_ROLE_KEY (same one the mailer uses) to read members.
# VAPID_PUBLIC_KEY=
# VAPID_PRIVATE_KEY=
# VAPID_SUBJECT=mailto:alerts@yourdomain.com
# APP_URL=https://mlr-app-omega.vercel.app   # deep-link + notification icon base

# ── Alert emails (optional) ──────────────────────────────────────────────────
# When set, the mini emails opted-in members whenever an app admin or Family Fest
# lead posts a broadcast alert. Leave any blank to keep emailing OFF (the in-app
# banner still works). See alert-mailer.js.
#
# ⚠️ SERVICE ROLE KEY is powerful — it bypasses row-level security to read member
# emails. Keep it ONLY here on the mini; never put it in the app/client.
# SUPABASE_SERVICE_ROLE_KEY=
#
# SMTP — reuse the SAME credentials you already set up in Supabase Auth → SMTP
# (any provider works). Port 465 ⇒ TLS; 587 ⇒ STARTTLS (or set SMTP_SECURE=true).
# SMTP_HOST=smtp.your-provider.com
# SMTP_PORT=587
# SMTP_USER=your-smtp-username
# SMTP_PASS=your-smtp-password
# ALERT_FROM=Muskellunge Lake Resort <alerts@yourdomain.com>   # match your sender
# APP_URL=https://mlr-app-omega.vercel.app
#
# (Gmail shortcut instead of the SMTP_* block: a Gmail address + an APP password
#  from https://myaccount.google.com/apppasswords)
# GMAIL_USER=you@gmail.com
# GMAIL_APP_PASSWORD=xxxxxxxxxxxxxxxx
